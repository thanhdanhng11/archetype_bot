# Database Configuration (Matches docker-compose.yml)
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=archetype_db

# Arbitrum Mainnet RPCs (Alchemy, Infura, QuickNode, etc.)
RPC_WSS_URL=wss://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ARBITRUM_MAINNET_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Bot Wallet Configuration
WALLET_ADDRESS=0xYourWalletAddress
PRIVATE_KEY=your_private_key_without_0x_prefix
ARCHETYPE_CONTRACT=0xContractAddressAfterDeployment
